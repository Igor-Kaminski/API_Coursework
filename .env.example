# Application
APP_NAME=Rail Reliability API
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rail_api
DATABASE_ECHO=false

# Simple coursework auth
ADMIN_API_KEY=change-me-admin-key
OPERATOR_API_KEY=change-me-operator-key
USER_API_KEY=change-me-user-key

# KnowledgeBase reference import
KB_STATIONS_URL=https://opendata.nationalrail.co.uk/api/staticfeeds/4.0/stations
KB_USERNAME=replace-with-local-value
KB_PASSWORD=replace-with-local-value

# Darwin journey import
DARWIN_SNAPSHOT_HOST=replace-with-local-value
DARWIN_SNAPSHOT_USERNAME=replace-with-local-value
DARWIN_SNAPSHOT_PASSWORD=replace-with-local-value
DARWIN_SNAPSHOT_DIRECTORY=snapshot

# Optional HSP validation
HSP_SERVICE_DETAILS_URL=https://hsp-prod.rockshore.net/api/v1/serviceDetails
HSP_SERVICE_METRICS_URL=https://hsp-prod.rockshore.net/api/v1/serviceMetrics

# Notes
# - Do not commit real credentials.
# - Keep real values only in your local .env file.
# - Public API endpoints should query PostgreSQL, not external feeds.